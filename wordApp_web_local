# 1. Database Manager
# ==========================================
class DatabaseManager:
    def __init__(self, db_name="vocab.db"):
        self.db_name = db_name
        self.create_tables()

    def get_connection(self):
        conn = sqlite3.connect(self.db_name)
        conn.row_factory = sqlite3.Row
        return conn

    def create_tables(self):
        conn = self.get_connection()
        cursor = conn.cursor()
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS words (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                unit TEXT,
                word TEXT,
                pos TEXT,
                definition TEXT,
                sentence TEXT,
                correct_count INTEGER DEFAULT 0,
                wrong_count INTEGER DEFAULT 0,
                UNIQUE(unit, word)
            )
        ''')
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS users (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT UNIQUE,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        conn.commit()
        conn.close()

    def add_word(self, unit, word, pos, definition, sentence):
        conn = self.get_connection()
        try:
            conn.execute('''
                INSERT OR IGNORE INTO words (unit, word, pos, definition, sentence)
                VALUES (?, ?, ?, ?, ?)
            ''', (unit, word, pos, definition, sentence))
            conn.commit()
        except Exception as e:
            print(f"DB Error: {e}")
        finally:
            conn.close()

    def clear_all_data(self):
        conn = self.get_connection()
        try:
            conn.execute("DELETE FROM words")
            conn.execute("DELETE FROM sqlite_sequence WHERE name='words'")
            conn.commit()
            return True
        except Exception as e:
            print(f"Clear Data Error: {e}")
            return False
        finally:
            conn.close()

    def get_units(self):
        conn = self.get_connection()
        cursor = conn.execute("SELECT DISTINCT unit FROM words ORDER BY unit DESC")
        units = [row[0] for row in cursor.fetchall()]
        conn.close()
        return units

    def get_words_by_unit(self, unit_name):
        conn = self.get_connection()
        cursor = conn.execute("SELECT * FROM words WHERE unit = ? ORDER BY id ASC", (unit_name,))
        words = [dict(row) for row in cursor.fetchall()]
        conn.close()
        return words

    def get_all_words(self):
        conn = self.get_connection()
        cursor = conn.execute("SELECT * FROM words")
        words = [dict(row) for row in cursor.fetchall()]
        conn.close()
        return words

    # --- User APIs ---
    def add_user(self, name):
        conn = self.get_connection()
        try:
            conn.execute("INSERT INTO users (name) VALUES (?)", (name,))
            conn.commit()
            return True
        except sqlite3.IntegrityError:
            return False
        except Exception as e:
            print(f"Add User Error: {e}")
            return False
        finally:
            conn.close()

    def get_users(self):
        conn = self.get_connection()
        cursor = conn.execute("SELECT id, name FROM users ORDER BY id")
        users = [{"id": row[0], "name": row[1]} for row in cursor.fetchall()]
        conn.close()
        return users

    def delete_user(self, user_id):
        conn = self.get_connection()
        try:
            conn.execute("DELETE FROM users WHERE id = ?", (user_id,))
            conn.commit()
        except Exception as e:
            print(f"Delete User Error: {e}")
        finally:
            conn.close()

db = DatabaseManager()

